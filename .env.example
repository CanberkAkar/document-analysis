# ============================================
# AI Hukuk Asistanı — Ortam Değişkenleri
# ============================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun:
#   cp .env.example .env

# ─── OpenAI API ───────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key-here

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_DB=legal_db

# ─── Qdrant Vector DB ────────────────────────────────────────
QDRANT_URL=http://qdrant:6333

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET=super_secret_legal_key_123!

# ─── Admin Hesabı (İlk çalıştırmada otomatik oluşturulur) ────
ADMIN_EMAIL=admin@hukuk.ai
ADMIN_PASSWORD=Admin123!

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000

# ─── Güvenli Haberleşme (AES-256-CBC & SHA-256) ───────────────
COMMUNICATION_SECRET=super_secret_comm_key_123!
NEXT_PUBLIC_COMMUNICATION_SECRET=super_secret_comm_key_123!
